{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "composite": false,
    "noEmit": true,
    "paths": {
      "~/*": ["./src/*"]
    },
    "strictNullChecks": true
  },
  "include": ["src/**/*", "vite.config.ts", "vitest.config.ts", "vite-env.d.ts"],
  "exclude": ["src/__tests__/**", "**/*.test.ts", "**/*.test.tsx"]
}
